# Backend (.env in server folder)
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pathfinder
JWT_SECRET=your_jwt_secret_key_here_make_it_strong_and_unique
OPENAI_API_KEY=your_openai_api_key_here
NODE_ENV=production

# Cors
CORS_ORIGIN=https://pathfinder.vercel.app

# Frontend (.env in client folder - VITE_API_URL)
VITE_API_URL=https://pathfinder-backend.herokuapp.com